# ============================================
# Avito Parser — переменные окружения
# Мониторинг краткосрочной аренды
# Скопируйте этот файл как .env и заполните значения:
#   cp .env.example .env
# ============================================

# --------------------------------------------
# Avito — ОБЯЗАТЕЛЬНЫЕ
# --------------------------------------------
# URL категории Avito с фильтрами
# Пример для посуточной аренды в СПб:
# https://www.avito.ru/sankt-peterburg/kvartiry/sdam/posutochno
AVITO_CATEGORY_URL=

# --------------------------------------------
# Браузер — необязательные
# --------------------------------------------
# Режим без графического интерфейса (true/false)
HEADLESS_MODE=false

# Таймаут навигации в миллисекундах
NAVIGATION_TIMEOUT=90000

# Время ожидания после загрузки страницы (мс)
PAGE_WAIT_TIME=30000

# Максимальное количество страниц пагинации (0 = все страницы)
MAX_PAGES=5

# --------------------------------------------
# База данных — необязательные
# --------------------------------------------
# Путь к файлу SQLite базы данных
DB_PATH=data/avito_listings.db

# --------------------------------------------
# Экспорт — необязательные
# --------------------------------------------
# Путь к выходному Excel-файлу
EXPORT_PATH=data/avito_report.xlsx

# --------------------------------------------
# Логирование — необязательные
# --------------------------------------------
# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Путь к файлу логов (если пусто — только консоль)
LOG_FILE_PATH=
